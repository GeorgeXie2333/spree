# Docker images
SPREE_VERSION_TAG=5.4.3.1

# Generated automatically on the first deployment. Leave empty here.
POSTGRES_PASSWORD=
SECRET_KEY_BASE=

# Initial Spree administrator
ADMIN_EMAIL=admin@cenwatch.com
ADMIN_PASSWORD=

# Docker-internal Spree API URL used by the storefront container
SPREE_API_URL=http://web:3000

# Public storefront URL served later through 1Panel
SITE_URL=https://shop.cenwatch.com

# Generated automatically after Spree starts
SPREE_PUBLISHABLE_KEY=

# Optional Stripe keys. Both must belong to the same Stripe account.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Storefront contact destination
CONTACT_TO_EMAIL=hello@cenwatch.com
