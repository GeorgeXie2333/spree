# See https://docs.docker.com/engine/reference/builder/#dockerignore-file

# Ignore git directory
.git/
.gitignore

# Ignore node/TS packages except the workspace manifests needed by
# apps/storefront/Dockerfile for root-context pnpm installs.
node_modules/
apps/storefront/.next/
apps/storefront/node_modules/
apps/storefront/.turbo/
**/.env*
!**/.env.example
!**/.env.local.example
packages/*
!packages/cli/
!packages/cli/package.json
!packages/admin-sdk/
!packages/admin-sdk/package.json
!packages/sdk-core/
!packages/sdk-core/package.json
turbo.json

# Ignore docs
docs/

# Ignore server-specific dev files
server/.bundle
server/.env*
server/config/master.key
server/config/credentials/*.key
server/log/*
server/tmp/*
server/storage/*
server/tmp/storage/*
server/node_modules/
server/app/assets/builds/*
server/public/assets
server/.devcontainer
server/.dockerignore
server/Dockerfile*

# Ignore spec/test artifacts in gems
spree/*/spec/dummy
spree/**/coverage
